---
import AppLayout from '../layouts/AppLayout';

type BackgroundEntry = { id: string; url: string; display_url?: string; name?: string };

// Hardcoded fallback if the API is unreachable — these are the Supabase Storage public URLs
const FALLBACK_BACKGROUNDS: Record<string, string> = {
  'sequoia': 'https://nboqjlagbujihaheucjp.supabase.co/storage/v1/object/public/backgrounds/sequoia.jpg',
  'sonoma': 'https://nboqjlagbujihaheucjp.supabase.co/storage/v1/object/public/backgrounds/sonoma.jpg',
  'ventura': 'https://nboqjlagbujihaheucjp.supabase.co/storage/v1/object/public/backgrounds/ventura.jpg',
};

// Fetch backgrounds from API using Astro.site (avoids internal Vercel URL on cold starts)
let backgrounds: BackgroundEntry[] = [];
let backgroundMap: Record<string, string> = {};

try {
  const siteUrl = Astro.site?.origin || import.meta.env.PUBLIC_SITE_URL || Astro.url.origin;
  const apiUrl = `${siteUrl}/api/content/backgrounds`;
  const response = await fetch(apiUrl);
  if (response.ok) {
    backgrounds = (await response.json()) as BackgroundEntry[];
  } else {
    console.warn('[LandingPage] API returned status %d for %s', response.status, apiUrl);
  }
} catch (error) {
  console.warn('[LandingPage] Failed to fetch backgrounds from API:', error instanceof Error ? error.message : error);
}

// Build background map from API results, using the name as key if available
backgroundMap = Object.fromEntries(
  backgrounds.map((bg) => [bg.name || bg.id, bg.url])
);

// If no API backgrounds, use hardcoded fallbacks
if (Object.keys(backgroundMap).length === 0) {
  backgroundMap = FALLBACK_BACKGROUNDS;
}

function getRandomBackground() {
  const bgKeys = Object.keys(backgroundMap);
  if (bgKeys.length === 0) return '';
  return bgKeys[Math.floor(Math.random() * bgKeys.length)];
}
---

<AppLayout
  client:load
  initialBg={getRandomBackground()}
  backgroundMap={backgroundMap}
/>
